{
  "name": "@zfadhli/base-ts",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "description": "A TypeScript library starter template",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "ci": "bun run typecheck && bun run lint && bun run test && bun run build",
    "release": "bun run build && bunx changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.29.0",
    "bun-types": "^1.3.14",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
